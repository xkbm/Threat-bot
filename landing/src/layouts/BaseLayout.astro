---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const { title = 'Threat — Seguridad Inteligente para Discord', description = 'Bot de seguridad para Discord con análisis de URLs, detección NSFW, anti-spam y más. Protege tu servidor con Threat.', canonical = Astro.url.pathname } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth" style="color-scheme: dark;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://threat-bot-discord.vercel.app/ogimage.png" />
    <meta property="og:url" content="https://threat-bot-discord.vercel.app" />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={`https://threat-bot-discord.vercel.app${canonical}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Threat",
      "url": "https://threat-bot-discord.vercel.app",
      "description": "Bot de seguridad para Discord con análisis de URLs, detección NSFW, anti-spam y más.",
      "logo": "https://threat-bot-discord.vercel.app/ogimage.png"
    }
    </script>

    <title>{title}</title>
  </head>
  <body class="bg-surface-900 text-surface-100 font-sans antialiased">
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <header class="fixed top-0 left-0 right-0 z-50 glass" style="padding-left: env(safe-area-inset-left, 0px); padding-right: env(safe-area-inset-right, 0px);">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 sm:px-6 py-4">
        <a href="/" class="text-lg font-bold tracking-tight text-white">Threat</a>

        <div class="hidden sm:flex items-center gap-6 text-sm text-surface-300">
          <a href="#features" class="nav-link transition-colors hover:text-white">Características</a>
          <a href="#how-it-works" class="nav-link transition-colors hover:text-white">Cómo funciona</a>
          <a href="#commands" class="nav-link transition-colors hover:text-white">Comandos</a>
        </div>

        <button id="menu-btn" class="sm:hidden flex items-center justify-center w-8 h-8 text-surface-300 hover:text-white transition-colors" aria-label="Menú" aria-expanded="false">
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/></svg>
          <svg class="w-5 h-5 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
        </button>
      </nav>

      <div id="mobile-menu" class="sm:hidden max-h-0 opacity-0 overflow-hidden transition-all duration-300 ease-out-expo">
        <div class="border-t border-surface-700 px-4 py-3 flex flex-col gap-3 text-sm text-surface-300 bg-surface-850/95 backdrop-blur-lg">
          <a href="#features" class="menu-link block transition-colors hover:text-white py-1.5">Características</a>
          <a href="#how-it-works" class="menu-link block transition-colors hover:text-white py-1.5">Cómo funciona</a>
          <a href="#commands" class="menu-link block transition-colors hover:text-white py-1.5">Comandos</a>
        </div>
      </div>
    </header>

    <script type="module">
      document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('menu-btn');
        const menu = document.getElementById('mobile-menu');
        const svgs = btn?.querySelectorAll('svg');

        if (!btn || !menu || !svgs?.length) return;

        btn.addEventListener('click', () => {
          const isClosed = menu.classList.contains('max-h-0');
          menu.classList.toggle('max-h-0');
          menu.classList.toggle('opacity-0');
          menu.classList.toggle('opacity-100');
          menu.classList.toggle('max-h-48', isClosed);
          svgs.forEach((svg) => svg.classList.toggle('hidden'));
          btn.setAttribute('aria-expanded', String(!isClosed));
        });

        document.querySelectorAll('.menu-link').forEach((link) => {
          link.addEventListener('click', () => {
            menu.classList.add('max-h-0', 'opacity-0');
            menu.classList.remove('opacity-100', 'max-h-48');
            svgs.forEach((svg, i) => {
              if (i === 0) svg.classList.remove('hidden');
              else svg.classList.add('hidden');
            });
            btn.setAttribute('aria-expanded', 'false');
          });
        });
      });
    </script>

    <main id="main-content">
      <slot />
    </main>

    <footer class="border-t border-surface-700 bg-surface-900">
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="flex flex-col items-center gap-4">
          <div class="flex items-center gap-6">
            <a href="/privacidad" class="text-xs text-surface-600 transition-colors hover:text-surface-400">Privacidad</a>
            <a href="/terminos" class="text-xs text-surface-600 transition-colors hover:text-surface-400">Términos</a>
          </div>
          <p class="text-xs text-surface-600">Threat &copy; {new Date().getFullYear()} — Seguridad inteligente para Discord</p>
        </div>
      </div>
    </footer>
  </body>
</html>
