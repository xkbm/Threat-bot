---
import '../styles/global.css';
import Icon from '../components/Icon.astro';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const { title = 'Threat — Seguridad Inteligente para Discord', description = 'Threat detecta URLs maliciosas, contenido NSFW y phishing en tu servidor de Discord. Análisis automático con VirusTotal y SightEngine. Gratis.', canonical = Astro.url.pathname } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth" style="color-scheme: dark;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://threat-bot-discord.vercel.app/ogimage.png" />
    <meta property="og:url" content={`https://threat-bot-discord.vercel.app${canonical}`} />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://threat-bot-discord.vercel.app/ogimage.png" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={`https://threat-bot-discord.vercel.app${canonical}`} />

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Threat",
      "url": "https://threat-bot-discord.vercel.app",
      "description": "Threat es un bot de seguridad gratuito para Discord que protege servidores mediante análisis automático de URLs, detección NSFW en imágenes, anti-scam y whitelist configurable.",
      "logo": "https://threat-bot-discord.vercel.app/ogimage.png"
    }
    </script>

    <title>{title}</title>
  </head>
  <body class="bg-surface-900 text-surface-100 font-sans antialiased">
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <header class="fixed top-0 inset-x-0 z-50 bg-surface-900/30 backdrop-blur-sm border-b border-white/5">
      <nav class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-lg font-bold tracking-tight text-white shrink-0">Threat</a>

        <div class="hidden sm:flex items-center gap-6 text-sm text-surface-400">
          <a href="/#features" class="hover:text-white transition-colors">Características</a>
          <a href="/#how-it-works" class="hover:text-white transition-colors">Cómo funciona</a>
          <a href="/#commands" class="hover:text-white transition-colors">Comandos</a>
        </div>

        <div class="flex items-center gap-1">
          <a href="https://top.gg/bot/1038186932456390726" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center justify-center rounded-full p-2.5 text-surface-400 hover:text-topgg transition-colors"
             aria-label="Top.gg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M0 4.3785h7.6215V12H2.329A2.3212 2.3212 0 0 1 .0077 9.6788Zm24 0H8.757v15.243h3.1144a4.5071 4.5071 0 0 0 4.507-4.5071V12h3.1145A4.5073 4.5073 0 0 0 24 7.4929Z"/>
            </svg>
          </a>
          <a href="https://discord.com/oauth2/authorize?client_id=1038186932456390726&permissions=277025745990&scope=bot+applications.commands&redirect_uri=https%3A%2F%2Fthreat-bot-discord.vercel.app%2Fthanks&response_type=code" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center justify-center rounded-full p-2.5 text-surface-400 hover:text-discord transition-colors"
             aria-label="Añadir a Discord">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
            </svg>
          </a>
        </div>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="border-t border-surface-800 bg-surface-900" style="padding-left: env(safe-area-inset-left, 0px); padding-right: env(safe-area-inset-right, 0px);">
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-3 sm:gap-6">
          <!-- Brand -->
          <div class="flex flex-col gap-2">
            <span class="text-sm font-bold text-white">Threat</span>
            <p class="text-xs text-surface-500 max-w-xs">
              Protección contra amenazas para tu servidor de Discord.
            </p>
          </div>
          <!-- Producto -->
          <div class="flex flex-col gap-2">
            <span class="text-xs font-semibold uppercase tracking-wider text-surface-400">Producto</span>
            <a href="/#features" class="text-xs text-surface-500 transition-colors duration-200 hover:text-surface-300">Características</a>
            <a href="/#how-it-works" class="text-xs text-surface-500 transition-colors duration-200 hover:text-surface-300">Cómo funciona</a>
            <a href="/#commands" class="text-xs text-surface-500 transition-colors duration-200 hover:text-surface-300">Comandos</a>
          </div>
          <!-- Legal -->
          <div class="flex flex-col gap-2">
            <span class="text-xs font-semibold uppercase tracking-wider text-surface-400">Legal</span>
            <a href="/privacidad" class="text-xs text-surface-500 transition-colors duration-200 hover:text-surface-300">Privacidad</a>
            <a href="/terminos" class="text-xs text-surface-500 transition-colors duration-200 hover:text-surface-300">Términos</a>
          </div>
        </div>
        <div class="mt-8 flex flex-col items-center gap-4 border-t border-surface-800 pt-6 sm:flex-row sm:justify-between">
          <p class="text-xs text-surface-600">Threat &copy; {new Date().getFullYear()}</p>
          <div class="flex items-center gap-4">
            <a href="https://github.com/xkbm" target="_blank" rel="noopener noreferrer"
               class="text-surface-500 transition-colors duration-200 hover:text-surface-300"
               aria-label="GitHub">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
            <a href="https://top.gg/bot/1038186932456390726" target="_blank" rel="noopener noreferrer"
               class="text-surface-500 transition-colors duration-200 hover:text-topgg"
               aria-label="Top.gg">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 4.3785h7.6215V12H2.329A2.3212 2.3212 0 0 1 .0077 9.6788Zm24 0H8.757v15.243h3.1144a4.5071 4.5071 0 0 0 4.507-4.5071V12h3.1145A4.5073 4.5073 0 0 0 24 7.4929Z"/>
              </svg>
            </a>
            <a href="https://discord.com/oauth2/authorize?client_id=1038186932456390726&permissions=277025745990&scope=bot+applications.commands&redirect_uri=https%3A%2F%2Fthreat-bot-discord.vercel.app%2Fthanks&response_type=code" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center rounded-full text-surface-500 transition-colors duration-200 hover:text-discord"
               aria-label="Añadir a Discord">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
