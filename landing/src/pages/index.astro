┌───────────────────────────────┐
│  zzZ                          │
│ (o.o)  Threat Bot             │
│ /|__|\  shh... está durmiendo │
│ github.com/xkbm/Threat-bot     │
└───────────────────────────────┘
-->
---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Stats from '../components/Stats.astro';

const threats = [
  {
    icon: 'link',
    title: 'Phishing',
    desc: 'Un miembro comparte un link de "free-nitro.download". Parece legítimo. No lo es. En 5 minutos puede comprometer todas las cuentas que hagan clic.',
  },
  {
    icon: 'eye',
    title: 'Contenido NSFW',
    desc: 'Alguien envía una imagen no deseada al canal general. Los menores de tu servidor la ven antes de que puedas actuar.',
  },
  {
    icon: 'comment-slash',
    title: 'Spam automatizado',
    desc: 'Un bot floodea enlaces acortados. Tus miembros no distinguen el spam de contenido real. El canal se vuelve inutilizable.',
  },
];

const stack = [
  { name: 'VirusTotal', desc: 'Análisis de URLs y archivos contra 70+ motores de antivirus' },
  { name: 'SightEngine', desc: 'Detección NSFW con 4 modelos: desnudos, armas, alcohol, ofensivo' },
  { name: 'Cache', desc: 'RAM + SQLite. URLs 7 días, archivos 30 días. Sin análisis repetidos' },
];

const keyCommands = [
  { name: '/scan', desc: 'Analiza cualquier archivo o URL manualmente' },
  { name: '/autoscan', desc: 'Activa el escaneo automático de mensajes' },
  { name: '/setlogchannel', desc: 'Canal donde Threat envía las alertas' },
];
---
<BaseLayout>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Qué tipo de amenazas detecta Threat?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Threat analiza URLs maliciosas (malware, phishing) mediante VirusTotal, detecta contenido NSFW (desnudos, armas, alcohol, ofensivo) con SightEngine, y previene spam con límites por usuario."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo configuro el bot en mi servidor?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Invita al bot con el enlace en la página, usa /setlogchannel para configurar el canal de logs. El modo silencioso y el modo estricto vienen activados por defecto, pero puedes ajustarlos con /silentmode y /strictmode."
        }
      },
      {
        "@type": "Question",
        "name": "¿Threat guarda mis datos personales?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Solo se almacenan datos necesarios para el funcionamiento: configuración del servidor y caché temporal de análisis. No almacenamos mensajes completos, información personal ni contenido de conversaciones."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta usar Threat?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Threat es completamente gratuito. Sin costos, sin planes pagos."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué hago si el bot marca un falso positivo?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Puedes agregar el dominio a la whitelist con /whitelist add."
        }
      }
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Threat",
    "applicationCategory": "SecurityApplication",
    "operatingSystem": "Discord",
    "description": "Bot de seguridad para Discord con análisis de URLs, detección NSFW, anti-spam y más.",
    "url": "https://threat-bot-discord.vercel.app",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  }
  </script>

  <!-- Hero -->
  <section class="section-scanline relative overflow-hidden flex flex-col min-h-[100dvh] px-6 pt-6">
    <div class="pointer-events-none absolute inset-0 z-0" style="background: radial-gradient(ellipse 800px 600px at 50% -100px, rgba(88,101,242,0.06), transparent);" aria-hidden="true"></div>
    <div class="flex-1 flex items-center justify-center mx-auto max-w-6xl w-full relative z-10">
      <div class="relative z-10 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 lg:gap-20 items-center lg:items-start">
          <!-- Left column -->
          <div class="text-center sm:text-left">
            <h1 class="mb-3 text-6xl font-extrabold leading-[0.9] tracking-tight text-white sm:text-6xl md:text-7xl lg:text-8xl">
              Threat
              <span class="block mt-2 text-xl font-semibold leading-snug tracking-tight text-surface-300 sm:text-3xl">
                Seguridad para tu servidor de Discord
              </span>
            </h1>
            <p class="mb-6 max-w-lg text-sm sm:text-base text-surface-400 md:text-xl leading-relaxed">
              URLs maliciosas, NSFW y phishing. Todo analizado en tiempo real.
            </p>
            <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start animate-fade-up-delayed">
              <a href="https://discord.com/oauth2/authorize?client_id=1038186932456390726&permissions=277025745990&scope=bot+applications.commands&redirect_uri=https%3A%2F%2Fthreat-bot-discord.vercel.app%2Fthanks&response_type=code" rel="noopener noreferrer" class="group cta-primary inline-flex items-center gap-3 rounded-full bg-discord px-7 py-3.5 font-semibold text-white">
                <Icon name="plus" />
                Añadir a Discord
                </span>
              </a>
            </div>
          </div>
          <!-- Chat mockup -->
          <div id="chat-mockup" class="w-full max-w-sm sm:max-w-md mx-auto lg:mx-0 text-left" aria-hidden="true">
            <div class="card-outer">
              <div class="card-inner-alt">
                <div class="border-b border-surface-700/50 px-3 sm:px-5 py-3 flex items-center gap-2">
                  <div class="flex items-center gap-1.5">
                    <span class="h-2 w-2 rounded-full bg-round1"></span>
                    <span class="h-2 w-2 rounded-full bg-round2"></span>
                    <span class="h-2 w-2 rounded-full bg-round3"></span>
                  </div>
                  <span class="ml-auto font-mono text-[10px] uppercase tracking-wider text-surface-500"># general</span>
                </div>
                <div class="space-y-4 px-3 sm:px-5 pt-4 pb-0">
                  <div class="chat-initial opacity-0">
                    <span class="font-mono text-xs font-medium text-surface-200">Alex</span>
                    <span class="mx-1.5 text-surface-600">—</span>
                    <span class="text-sm text-surface-300">¿Alguien tiene el link del nuevo asset?</span>
                  </div>
                  <div class="chat-initial opacity-0">
                    <span class="font-mono text-xs font-medium text-surface-200">María</span>
                    <span class="mx-1.5 text-surface-600">—</span>
                    <span class="text-sm text-surface-300">creo que sí, te lo paso</span>
                  </div>
                  <div id="chat-sent" class="opacity-0">
                    <span class="font-mono text-xs font-medium text-surface-200">h4ck3r_1337</span>
                    <span class="mx-1.5 text-surface-600">—</span>
                    <span class="chat-url-text break-all text-sm text-surface-100"></span>
                  </div>
                  <div id="chat-typing" class="opacity-0 transition-opacity duration-300">
                    <div class="flex items-center gap-1.5 text-sm text-surface-500">
                      <span class="flex h-1 w-1 rounded-full bg-surface-500 animate-[typing-dot_1.4s_infinite]"></span>
                      <span class="flex h-1 w-1 rounded-full bg-surface-500 animate-[typing-dot_1.4s_infinite_0.2s]"></span>
                      <span class="flex h-1 w-1 rounded-full bg-surface-500 animate-[typing-dot_1.4s_infinite_0.4s]"></span>
                      <span class="ml-1 text-xs">Threat está escribiendo</span>
                    </div>
                  </div>
                  <div id="chat-bot-response" class="opacity-0 min-h-[120px]">
                    <div class="mb-1 flex items-center gap-2">
                      <span class="font-mono text-xs font-medium text-white">Threat</span>
                      <span class="inline-flex items-center gap-0.5 rounded bg-discord px-1.5 py-[1px] text-[9px] font-semibold leading-normal text-white"><Icon name="check" class="text-white" size="9px" /> APP</span>
                    </div>
                    <div id="chat-response-card" class="hidden border-l-4 bg-surface-800 p-3.5">
                      <div class="mb-1 flex items-center gap-1.5">
                        <img id="chat-response-emoji" src="/emoji-warn.png" alt="" class="w-4 h-4" width="16" height="16" />
                        <span id="chat-response-title" class="text-sm font-semibold text-surface-100">Amenazas detectadas</span>
                      </div>
                      <p id="chat-response-desc" class="mb-2 text-xs text-surface-300"></p>
                      <div id="chat-response-url-field" class="hidden mb-2">
                        <div class="mb-0.5 text-[10px] font-semibold uppercase tracking-wider text-surface-500"><img src="/emoji-link.png" class="inline w-4 h-4" width="16" height="16" alt="" /> URLs</div>
                        <div id="chat-response-url-values" class="space-y-0.5"></div>
                      </div>
                      <div id="chat-response-nsfw-field" class="hidden mb-2">
                        <div class="mb-0.5 text-[10px] font-semibold uppercase tracking-wider text-alert-light"><img src="/emoji-nsfw.png" class="inline w-4 h-4" width="16" height="16" alt="" /> Imágenes (URL)</div>
                        <div id="chat-response-nsfw-values" class="space-y-0.5"></div>
                      </div>
                      <div id="chat-response-mal-field" class="hidden mb-2">
                        <div class="mb-0.5 text-[10px] font-semibold uppercase tracking-wider text-threat-light"><img src="/emoji-warn.png" class="inline w-4 h-4" width="16" height="16" alt="" /> Enlaces maliciosos</div>
                        <div id="chat-response-mal-values" class="space-y-0.5"></div>
                      </div>
                    </div>
                    <div id="chat-response-text" class="hidden text-sm text-surface-300">
                      <img src="/emoji-whitelist.png" alt="" class="inline w-4 h-4 mr-1" width="16" height="16" />
                      <strong class="text-surface-100">Dominio(s) en whitelist.</strong> No se requiere análisis.
                    </div>
                  </div>
                </div>
                <div class="mt-5 border-t border-surface-700/50 px-3 sm:px-5 py-3">
                  <div class="flex items-center gap-2 rounded-lg border border-surface-600 bg-surface-800 px-3 py-2 sm:px-4 sm:py-2.5 text-sm text-surface-500">
                    <span id="chat-input-text" class="flex-1 text-surface-500">Escribe un mensaje...</span>
                    <span id="chat-input-cursor" class="hidden inline-block h-[1.1em] w-[2px] bg-shield animate-composing-cursor"></span>
                    <Icon name="paperclip" />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <script type="module">
          document.addEventListener('DOMContentLoaded', () => {
            const usuarios = ['Alex', 'María', 'Carlos', 'Laura', 'Pedro', 'Sofía', 'Ana', 'Luis', 'Elena', 'Diego', 'Martín', 'Valentina', 'Joaquín', 'Camila', 'Rodrigo'];

            const escenarios = [
              {
                tipo: 'malicioso',
                urls: [
                  'https://free-nitro.download/claim',
                  'https://phishing-login.xyz/verify',
                  'https://steam-community.ru/free',
                  'https://verify-discord.xyz/gift',
                  'https://free-bitcoin.tk/claim',
                  'https://secure-update.ga/package',
                ],
                titulo: 'Amenazas detectadas',
                emoji: '/emoji-warn.png',
                borderColor: 'rgb(230, 126, 34)',
                titleClass: 'text-surface-100',
                tieneURL: true,
                tieneNSFW: false,
                desc: (det) => `Se analizó <strong class="text-surface-100">1</strong> elemento(s):<br/>${EMOJI_CHECK} Seguros: <strong class="text-surface-100">0</strong><br/>${EMOJI_WARN} Maliciosos: <strong class="text-surface-100">${det}</strong>`,
                conversaciones: [
                  { u1: '¿Alguien tiene el link del nuevo asset?', u2: 'creo que sí, te lo paso', urlFrom: 'u2' },
                  { u1: 'Me llegó un link raro', u2: '¿cuál es?', urlFrom: 'u1' },
                  { u1: 'Oye, te paso un enlace', u2: 'dale, mándalo', urlFrom: 'u1' },
                  { u1: 'Mira esto que me llegó al DM', u2: 'pásalo al general', urlFrom: 'u1' },
                  { u1: '¿Es seguro este enlace?', u2: 'no sé, pásalo a ver', urlFrom: 'u1' },
                  { u1: 'Necesito ayuda con un archivo', u2: 'tíralo aquí', urlFrom: 'u1' },
                ],
              },
              {
                tipo: 'seguro',
                urls: [
                  'https://github.com/discord.py/releases',
                  'https://stackoverflow.com/questions/12345678/how-to-extend-url',
                  'https://docs.python.org/3/tutorial/modules.html',
                  'https://tailwindcss.com/docs/installation',
                ],
                titulo: 'Todos los elementos son seguros',
                emoji: '/emoji-check.png',
                borderColor: 'var(--color-secure)',
                titleClass: 'text-surface-100',
                tieneURL: true,
                tieneNSFW: false,
                desc: () => `Se analizó <strong class="text-surface-100">1</strong> elemento(s):<br/>${EMOJI_CHECK} Seguros: <strong class="text-surface-100">1</strong>`,
                conversaciones: [
                  { u1: '¿Alguien ha usado esto?', u2: 'sí, es confiable', urlFrom: 'u1' },
                  { u1: 'Mira el repo nuevo', u2: '¿qué hay?', urlFrom: 'u1' },
                  { u1: '¿Alguien tiene el link?', u2: 'sí, aquí va', urlFrom: 'u2' },
                  { u1: '¿Me pasan el enlace?', u2: 'claro, aquí va', urlFrom: 'u2' },
                ],
              },
              {
                tipo: 'whitelist',
                urls: [
                  'https://www.youtube.com/watch?v=dQw4w9WgXcQ',
                  'https://www.twitch.tv/directory',
                  'https://open.spotify.com/playlist/37i9dQZF1DXcBWIGoYBM5M',
                ],
                titulo: '',
                emoji: '/emoji-whitelist.png',
                borderColor: 'var(--color-secure)',
                titleClass: 'text-surface-100',
                tieneURL: false,
                tieneNSFW: false,
                desc: () => '',
                conversaciones: [
                  { u1: 'Miren este video', u2: '¿de qué trata?', urlFrom: 'u1' },
                  { u1: 'Pasen la playlist nueva', u2: 'aquí la tienes', urlFrom: 'u2' },
                  { u1: '¿Alguien tiene el link del stream?', u2: 'sí, aquí va', urlFrom: 'u2' },
                ],
              },
            ];
            const EMOJI_CHECK = '<img src="/emoji-check.png" class="inline w-4 h-4" width="16" height="16" alt="" />';
            const EMOJI_WARN = '<img src="/emoji-warn.png" class="inline w-4 h-4" width="16" height="16" alt="" />';
            const EMOJI_LINK_CHAIN = '<img src="/emoji-link.png" class="inline w-4 h-4" width="16" height="16" alt="" />';

            function rand(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

            const roll = Math.random();
            const escenario = roll < 0.5 ? escenarios[0] : roll < 0.8 ? escenarios[1] : escenarios[2];
            const url = rand(escenario.urls);
            const conv = rand(escenario.conversaciones);

            const u1Name = rand(usuarios);
            let u2Name;
            do { u2Name = rand(usuarios); } while (u2Name === u1Name);

            const urlSender = conv.urlFrom === 'u2' ? u2Name : u1Name;

            const responseCard = document.getElementById('chat-response-card');
            const responseText = document.getElementById('chat-response-text');
            const responseEmoji = document.getElementById('chat-response-emoji');
            const responseTitle = document.getElementById('chat-response-title');
            const responseDesc = document.getElementById('chat-response-desc');
            const responseUrlField = document.getElementById('chat-response-url-field');
            const responseUrlValues = document.getElementById('chat-response-url-values');
            const responseNsfwField = document.getElementById('chat-response-nsfw-field');
            const responseNsfwValues = document.getElementById('chat-response-nsfw-values');
            const responseMalField = document.getElementById('chat-response-mal-field');
            const responseMalValues = document.getElementById('chat-response-mal-values');

            if (escenario.tipo === 'whitelist') {
              responseCard.classList.add('hidden');
              responseText.classList.remove('hidden');
            } else {
              responseCard.classList.remove('hidden');
              responseText.classList.add('hidden');
              responseCard.style.borderLeftColor = escenario.borderColor;
              responseEmoji.src = escenario.emoji;
              responseTitle.textContent = escenario.titulo;
              responseTitle.setAttribute('class', `text-sm font-semibold ${escenario.titleClass}`);

              const det = Math.floor(Math.random() * 22) + 3;
              responseDesc.innerHTML = escenario.desc(det);

              // URL field
              if (escenario.tieneURL) {
                responseUrlField.classList.remove('hidden');
                responseUrlValues.innerHTML = escenario.tipo === 'malicioso'
                  ? `<span class="text-xs text-surface-300">${EMOJI_WARN} <code class="font-mono text-xs text-surface-200 bg-surface-700 px-1 py-0.5 rounded">${url}</code></span>`
                  : `<span class="text-xs text-surface-300">${EMOJI_CHECK} <code class="font-mono text-xs text-surface-200 bg-surface-700 px-1 py-0.5 rounded">${url}</code></span>`;
              } else {
                responseUrlField.classList.add('hidden');
              }

              // NSFW field
              responseNsfwField.classList.add('hidden');

              // Malicious links field
              if (escenario.tipo === 'malicioso') {
                responseMalField.classList.remove('hidden');
                const urlId = btoa(url).replace(/=+$/, '');
                const vtLink = `https://www.virustotal.com/gui/url/${urlId}`;
                responseMalValues.innerHTML = `<span class="text-xs text-surface-300">• <code class="font-mono text-xs text-surface-200 bg-surface-700 px-1 py-0.5 rounded">${url}</code> <a href="${vtLink}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-0.5 text-shield-light hover:underline">${EMOJI_LINK_CHAIN} Ver informe</a></span>`;
              } else {
                responseMalField.classList.add('hidden');
              }
            }

            const chatInitials = document.querySelectorAll('.chat-initial');
            chatInitials[0].querySelector('.font-mono').textContent = u1Name;
            chatInitials[0].querySelector('.text-surface-300').textContent = conv.u1;
            chatInitials[1].querySelector('.font-mono').textContent = u2Name;
            chatInitials[1].querySelector('.text-surface-300').textContent = conv.u2;

            document.querySelectorAll('.chat-url-text, .chat-url').forEach((el) => el.textContent = url);
            document.querySelector('#chat-sent .font-mono').textContent = urlSender;

            const inputText = document.getElementById('chat-input-text');
            const inputCursor = document.getElementById('chat-input-cursor');
            const sentMsg = document.getElementById('chat-sent');
            const typingInd = document.getElementById('chat-typing');
            const botResponse = document.getElementById('chat-bot-response');
            setTimeout(() => {
              chatInitials.forEach((el, i) => {
                setTimeout(() => {
                  el.classList.remove('opacity-0');
                  el.classList.add('animate-slide-up');
                }, i * 200);
              });
              setTimeout(() => {
                inputText.classList.remove('text-surface-500');
                inputText.classList.add('text-surface-100');
                inputText.textContent = '';
                inputCursor.classList.remove('hidden');
                let i = 0;
                function typeChar() {
                  inputText.textContent = url.slice(0, i + 1);
                  i++;
                  if (i < url.length) {
                    setTimeout(typeChar, 55);
                  } else {
                    inputText.textContent = url;
                    inputCursor.classList.add('hidden');
                    inputText.classList.remove('text-surface-100');
                    inputText.classList.add('text-surface-500');
                    inputText.textContent = 'Escribe un mensaje...';
                    setTimeout(() => {
                      sentMsg.classList.remove('opacity-0');
                      sentMsg.classList.add('animate-slide-up');
                      setTimeout(() => {
                        typingInd.classList.remove('opacity-0');
                        setTimeout(() => {
                          typingInd.classList.add('opacity-0');
                          botResponse.classList.remove('opacity-0');
                          botResponse.classList.add('animate-slide-up');
                        }, 800);
                      }, 500);
                    }, 500);
                  }
                }
                typeChar();
              }, 600);
            }, 500);
          });
        </script>
      </div>
    </div>
    <div class="flex justify-center">
      <a href="#threats" class="cursor-pointer text-surface-500 transition-colors duration-200 hover:text-surface-300">
        <Icon name="chevron-down" size="1.25em" />
      </a>
    </div>
  </section>

  <!-- Threats: Esto es lo que ve tu servidor cada día -->
  <section id="threats" class="scroll-reveal relative border-t border-surface-800 bg-surface-900 px-6 py-20 sm:py-28" data-reveal="scale">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-4xl font-bold tracking-tight text-white md:text-5xl">
          Esto es lo que ve tu servidor cada día
        </h2>
        <p class="mx-auto max-w-2xl text-surface-400">
          No son casos extremos. Son las amenazas más comunes en servidores de Discord.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-surface-800">
        {threats.map((t) => (
          <div class="spotlight-item relative bg-surface-900 p-6 sm:p-8">
            <h3 class="mb-3 text-xl font-semibold text-white">{t.title}</h3>
            <p class="text-sm leading-relaxed text-surface-400">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Demo: Así reacciona Threat -->
  <section id="demo" class="scroll-reveal section-scanline relative border-t border-surface-800 bg-surface-850 px-6 py-24 sm:py-32" data-reveal="none">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-4xl font-bold tracking-tight text-white md:text-5xl">
          Así reacciona Threat
        </h2>
        <p class="mx-auto max-w-2xl text-surface-400">
          Un mensaje llega. Threat analiza. Recibes la alerta. Todo en segundos.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Escenarios -->
        <div class="flex flex-col gap-6">
          <div class="spotlight-item relative border border-surface-800 rounded-xl p-5 sm:p-6" id="scenario-phishing">
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-threat/10 text-xl text-threat-light">
                <Icon name="link" />
              </div>
              <div>
                <h3 class="mb-1 text-lg font-semibold text-white">Phishing detectado</h3>
                <p class="text-sm text-surface-400">Un miembro envía <code class="font-mono text-xs text-surface-200 bg-surface-800 px-1.5 py-0.5 rounded">free-nitro.download/claim</code>. Threat lo analiza contra 70+ motores de antivirus y alerta al canal de logs.</p>
              </div>
            </div>
          </div>

          <div class="spotlight-item relative border border-surface-800 rounded-xl p-5 sm:p-6" id="scenario-nsfw">
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-alert/10 text-xl text-alert-light">
                <Icon name="eye" />
              </div>
              <div>
