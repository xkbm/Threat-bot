---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

const features = [
  {
    icon: 'shield-alt',
    title: 'Análisis de URLs',
    description: 'Cada enlace se expande y verifica contra VirusTotal.',
    featured: true,
  },
  {
    icon: 'eye',
    title: 'Detección NSFW',
    description: 'SightEngine: desnudos, armas, alcohol y contenido ofensivo. Descarga segura sin exponer tu IP.',
  },
  {
    icon: 'ban',
    title: 'Anti-Spam',
    description: '30 URLs/hora por usuario, cooldown de 10s entre análisis.',
  },

  {
    icon: 'database',
    title: 'Cache',
    description: 'RAM + SQLite con expiración automática. URLs 7 días, archivos 30 días.',
    closing: true,
  },
  {
    icon: 'check-double',
    title: 'Whitelist',
    description: 'Dominios protegidos no removibles. Coincide dominio y subdominios automáticamente.',
    closing: true,
  },
];

const commands = [
  { name: '/scan', desc: 'Analiza un archivo o URL', icon: 'search' },
  { name: '/silentmode', desc: 'Modo silencioso (sin alerts públicos)', icon: 'volume-mute' },
  { name: '/strictmode', desc: 'Elimina mensajes con amenazas', icon: 'gavel' },
  { name: '/setlogchannel', desc: 'Configura canal de logs', icon: 'hashtag' },
  { name: '/settings', desc: 'Ver configuración del servidor', icon: 'cog' },
  { name: '/whitelist', desc: 'Gestionar dominios permitidos', icon: 'list' },
  { name: '/stats', desc: 'Estadísticas globales', icon: 'chart-bar' },
  { name: '/help', desc: 'Lista completa de comandos', icon: 'question-circle' },
];

const steps = [
  {
    icon: 'envelope',
    title: 'Llega un mensaje',
    desc: 'Cada mensaje nuevo o editado se analiza al instante. URLs, imágenes y archivos adjuntos. Máximo 5 archivos por mensaje.',
  },
  {
    icon: 'expand-arrows-alt',
    title: 'Análisis',
    desc: 'Whitelist omite dominios conocidos. Anti-spam verifica límites. Acortadores expandidos hasta 5 saltos. Cache RAM + SQLite evita reanálisis.',
  },
  {
    icon: 'cloud-upload-alt',
    title: 'APIs externas',
    desc: 'VirusTotal analiza URLs y archivos. SightEngine escanea imágenes con 4 modelos: desnudos, armas, alcohol y ofensivo.',
  },
  {
    icon: 'bell',
    title: 'Alerta y acción',
    desc: 'Recibes el resultado y puedes actuar directamente: Ban, Kick o Ignorar.',
  },
];
---
<BaseLayout>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Qué tipo de amenazas detecta Threat?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Threat analiza URLs maliciosas (malware, phishing) mediante VirusTotal, detecta contenido NSFW (desnudos, armas, alcohol, ofensivo) con SightEngine, y previene spam con límites por usuario."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo configuro el bot en mi servidor?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Invita al bot con el enlace en la página, usa /setlogchannel para configurar el canal de logs, y opcionalmente /silentmode o /strictmode según tus necesidades."
        }
      },
      {
        "@type": "Question",
        "name": "¿Threat guarda mis datos personales?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Solo almacenamos datos necesarios para el funcionamiento: configuración del servidor y caché temporal de análisis. No almacenamos mensajes completos, información personal ni contenido de conversaciones."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta usar Threat?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Threat es completamente gratuito. Sin costos, sin planes pagos."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué hago si el bot marca un falso positivo?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Puedes agregar el dominio a la whitelist con /whitelist add. Si consideras que es un error recurrente, contacta al desarrollador para revisar el caso."
        }
      }
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Threat",
    "applicationCategory": "SecurityApplication",
    "operatingSystem": "Discord",
    "description": "Bot de seguridad para Discord con análisis de URLs, detección NSFW, anti-spam y más.",
    "url": "https://threat-bot-discord.vercel.app",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  }
  </script>

  <!-- HERO -->
  <section class="section-scanline relative overflow-hidden flex flex-col min-h-[100dvh] px-6 pt-20">
    <div class="pointer-events-none absolute inset-0 z-0" style="background: radial-gradient(ellipse 800px 600px at 50% -100px, rgba(88,101,242,0.06), transparent);" aria-hidden="true"></div>
    <div class="flex-1 flex items-center justify-center mx-auto max-w-6xl w-full relative z-10">
      <div class="relative z-10 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-start">
          <!-- Left column -->
          <div class="text-left">
            <h1 class="mb-5 text-5xl font-black leading-[0.9] tracking-tight text-white sm:text-6xl md:text-7xl lg:text-8xl">
              Threat
              <span class="block mt-3 text-2xl font-semibold leading-snug tracking-tight text-surface-300 sm:text-3xl">
                Seguridad para tu servidor de Discord
              </span>
            </h1>
            <p class="mb-8 max-w-lg text-base text-surface-400 sm:text-lg md:text-xl leading-relaxed">
              URLs maliciosas, NSFW y phishing. Todo analizado en tiempo real.
            </p>
            <div class="flex flex-col items-start gap-4 sm:flex-row animate-fade-up-delayed">
              <a href="https://discord.com/oauth2/authorize?client_id=1038186932456390726&permissions=277025745990&scope=bot+applications.commands&redirect_uri=https%3A%2F%2Fthreat-bot-discord.vercel.app%2Fthanks&response_type=code" target="_blank" rel="noopener noreferrer" class="group cta-primary inline-flex items-center gap-3 rounded-full bg-discord px-7 py-3.5 font-semibold text-white">
                <Icon name="plus" />
                Añadir a Discord
                <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center transition-transform duration-200 group-hover:translate-x-0.5">
                  <Icon name="arrow-right" size="0.75em" />
                </span>
              </a>
            </div>
          </div>
          <!-- Chat mockup -->
          <div id="chat-mockup" class="w-full max-w-md mx-auto lg:mx-0 text-left">
            <div class="card-outer">
              <div class="card-inner-alt">
                <div class="border-b border-surface-700/50 px-3 sm:px-5 py-3 flex items-center gap-2">
                  <div class="flex items-center gap-1.5">
                    <span class="h-2 w-2 rounded-full bg-threat"></span>
                    <span class="h-2 w-2 rounded-full bg-surface-600"></span>
                    <span class="h-2 w-2 rounded-full bg-surface-600"></span>
                  </div>
                  <span class="ml-auto font-mono text-[10px] uppercase tracking-wider text-surface-500"># general</span>
                </div>
                <div class="space-y-4 px-3 sm:px-5 pt-4 pb-0">
                  <div class="chat-initial opacity-0">
                    <span class="font-mono text-xs font-medium text-surface-200">Alex</span>
                    <span class="mx-1.5 text-surface-600">—</span>
                    <span class="text-sm text-surface-300">¿Alguien tiene el link del nuevo asset?</span>
                  </div>
                  <div class="chat-initial opacity-0">
                    <span class="font-mono text-xs font-medium text-surface-200">María</span>
                    <span class="mx-1.5 text-surface-600">—</span>
                    <span class="text-sm text-surface-300">creo que sí, te lo paso</span>
                  </div>
                  <div id="chat-sent" class="opacity-0">
                    <span class="font-mono text-xs font-medium text-threat-light">h4ck3r_1337</span>
                    <span class="mx-1.5 text-surface-600">—</span>
                    <span class="chat-url-text break-all text-sm text-surface-100"></span>
                  </div>
                  <div id="chat-typing" class="opacity-0 transition-opacity duration-300">
                    <div class="flex items-center gap-1.5 text-sm text-surface-500">
                      <span class="flex h-1 w-1 rounded-full bg-surface-500 animate-[typing-dot_1.4s_infinite]"></span>
                      <span class="flex h-1 w-1 rounded-full bg-surface-500 animate-[typing-dot_1.4s_infinite_0.2s]"></span>
                      <span class="flex h-1 w-1 rounded-full bg-surface-500 animate-[typing-dot_1.4s_infinite_0.4s]"></span>
                      <span class="ml-1 text-xs">Threat está escribiendo</span>
                    </div>
                  </div>
                  <div id="chat-bot-response" class="opacity-0">
                    <div class="mb-1 flex items-center gap-2">
                      <span class="font-mono text-xs font-medium text-white">Threat</span>
                      <span class="inline-flex items-center gap-0.5 rounded bg-discord px-1.5 py-[1px] text-[9px] font-semibold leading-normal text-white"><Icon name="check" class="text-white" size="9px" /> APP</span>
                    </div>
                    <div id="chat-response-card" class="border-l-4 bg-surface-800 p-3.5" style="border-left-color: var(--color-threat);">
                      <div class="mb-1 flex items-center gap-1.5">
                        <Icon id="chat-response-icon" name="exclamation-triangle" class="text-threat-light" />
                        <span id="chat-response-title" class="text-sm font-semibold text-threat-light">URL Maliciosa Detectada</span>
                      </div>
                      <p id="chat-response-desc" class="mb-3 text-xs text-surface-300">
                        Se encontraron <strong class="text-surface-100">18</strong> detecciones
                      </p>
                      <div id="chat-response-url-section" class="mb-2">
                        <div class="mb-0.5 text-[10px] font-semibold uppercase tracking-wider text-surface-500">URL</div>
                        <code class="chat-url block truncate rounded bg-surface-700 px-2 py-1 font-mono text-xs text-surface-200"></code>
                      </div>
                      <span id="chat-response-link" class="inline-flex items-center gap-1 text-xs text-discord-light">
                        <Icon name="external-link-alt" /> Ver informe completo
                      </span>
                    </div>
                  </div>
                </div>
                <div class="mt-5 border-t border-surface-700/50 px-3 sm:px-5 py-3">
                  <div class="flex items-center gap-2 rounded-lg border border-surface-600 bg-surface-800 px-3 py-2 sm:px-4 sm:py-2.5 text-sm text-surface-500">
                    <span id="chat-input-text" class="flex-1 text-surface-500">Escribe un mensaje...</span>
                    <span id="chat-input-cursor" class="hidden inline-block h-[1.1em] w-[2px] bg-discord animate-composing-cursor"></span>
                    <Icon name="paperclip" />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <script type="module">
          document.addEventListener('DOMContentLoaded', () => {
            const usuarios = ['Alex', 'María', 'Carlos', 'Laura', 'Pedro', 'Sofía', 'Ana', 'Luis', 'Elena', 'Diego'];
            const usuariosMal = ['noise_38472', 'pxl_share', 'mark_online', 'vx_runner', 'rem_upload', 'crash_override', 'guest_001'];

            const escenarios = [
              // --- MALICIOSO ---
              {
                tipo: 'malicioso',
                urls: [
                  'https://free-nitro.download/claim',
                  'https://phishing-login.xyz/verify',
                  'https://steam-community.ru/free',
                  'https://verify-discord.xyz/gift',
                  'https://free-bitcoin.tk/claim',
                  'https://secure-update.ga/package',
                ],
                titulo: 'URL Maliciosa Detectada',
                borderColor: 'var(--color-threat)',
                titleClass: 'text-threat-light',
              },
              // --- SEGURO ---
              {
                tipo: 'seguro',
                urls: [
                  'https://github.com/discord.py/releases',
                  'https://stackoverflow.com/questions/12345',
                  'https://docs.python.org/3/tutorial',
                  'https://tailwindcss.com/docs',
                ],
                titulo: 'URL Segura',
                borderColor: 'var(--color-secure)',
                titleClass: 'text-secure-light',
              },
              // --- WHITELIST ---
              {
                tipo: 'whitelist',
                urls: [
                  'https://youtube.com/watch?v=dQw4w9WgXcQ',
                  'https://www.twitch.tv/directory',
                  'https://open.spotify.com/playlist/37i9dQZF1DXcBWIGoYBM5M',
                ],
                titulo: 'Dominio en Whitelist',
                borderColor: 'var(--color-discord)',
                titleClass: 'text-discord-light',
              },
            ];

            function rand(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
            function randDifferent(arr, exclude) {
              let v;
              do { v = rand(arr); } while (v === exclude);
              return v;
            }

            // Seleccionar escenario con pesos: 50% malicioso, 30% seguro, 20% whitelist
            const roll = Math.random();
            const escenario = roll < 0.5 ? escenarios[0] : roll < 0.8 ? escenarios[1] : escenarios[2];
            const url = rand(escenario.urls);

            // Seleccionar usuario según tipo
            const userSender = escenario.tipo === 'malicioso' ? rand(usuariosMal) : rand(usuarios);

            // Configurar el bot response dinámicamente
            const responseCard = document.getElementById('chat-response-card');
            const responseTitle = document.getElementById('chat-response-title');
            const responseDesc = document.getElementById('chat-response-desc');
            const responseUrlSection = document.getElementById('chat-response-url-section');
            const responseLink = document.getElementById('chat-response-link');

            responseCard.style.borderLeftColor = escenario.borderColor;
            responseTitle.textContent = escenario.titulo;
            responseTitle.setAttribute('class', `text-sm font-semibold ${escenario.titleClass}`);

            if (escenario.tipo === 'malicioso') {
              const det = Math.floor(Math.random() * 22) + 3;
              responseDesc.innerHTML = `Se encontraron <strong class="text-surface-100">${det}</strong> detecciones`;
              responseUrlSection.classList.remove('hidden');
              responseLink.classList.remove('hidden');
            } else if (escenario.tipo === 'seguro') {
              responseDesc.textContent = 'No se detectaron amenazas';
              responseUrlSection.classList.remove('hidden');
              responseLink.classList.add('hidden');
            } else {
              responseDesc.textContent = `${url.split('/')[2]} está en la lista de dominios permitidos`;
              responseUrlSection.classList.add('hidden');
              responseLink.classList.add('hidden');
            }

            // Configurar el mensaje del usuario
            document.querySelectorAll('.chat-url-text, .chat-url').forEach((el) => el.textContent = url);
            const sentUserEl = document.querySelector('#chat-sent .font-mono');
            sentUserEl.textContent = userSender;
            sentUserEl.className = escenario.tipo === 'malicioso'
              ? 'font-mono text-xs font-medium text-threat-light'
              : 'font-mono text-xs font-medium text-surface-200';

            const inputText = document.getElementById('chat-input-text');
            const inputCursor = document.getElementById('chat-input-cursor');
            const sentMsg = document.getElementById('chat-sent');
            const typingInd = document.getElementById('chat-typing');
            const botResponse = document.getElementById('chat-bot-response');
            const chatInitials = document.querySelectorAll('.chat-initial');
            setTimeout(() => {
              chatInitials.forEach((el, i) => {
                setTimeout(() => {
                  el.classList.remove('opacity-0');
                  el.classList.add('animate-slide-up');
                }, i * 200);
              });
              setTimeout(() => {
                inputText.classList.remove('text-surface-500');
                inputText.classList.add('text-surface-100');
                inputText.textContent = '';
                inputCursor.classList.remove('hidden');
                let i = 0;
                const interval = setInterval(() => {
                  inputText.textContent = url.slice(0, i + 1);
                  i++;
                  if (i >= url.length) {
                    clearInterval(interval);
                    inputText.textContent = url;
                    inputCursor.classList.add('hidden');
                    inputText.classList.remove('text-surface-100');
                    inputText.classList.add('text-surface-500');
                    inputText.textContent = 'Escribe un mensaje...';
                    setTimeout(() => {
                      sentMsg.classList.remove('opacity-0');
                      sentMsg.classList.add('animate-slide-up');
                      setTimeout(() => {
                        typingInd.classList.remove('opacity-0');
                        setTimeout(() => {
                          typingInd.classList.add('opacity-0');
                          botResponse.classList.remove('opacity-0');
                          botResponse.classList.add('animate-slide-up');
                        }, 800);
                      }, 500);
                    }, 500);
                  }
                }, 55);
              }, 600);
            }, 500);
          });
        </script>
      </div>
    </div>
    <div class="flex justify-center">
      <a href="#features" class="text-surface-600 transition-colors duration-200 hover:text-surface-400">
        <Icon name="chevron-down" size="1.25em" />
      </a>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="scroll-reveal relative border-t border-surface-800 bg-surface-900 px-6 py-20 sm:py-28" data-reveal="scale">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-4xl font-bold tracking-tight text-white md:text-5xl">
          Características
        </h2>
      </div>

      <div class="flex flex-col gap-6">
        <!-- Featured card (full-width) -->
        {features.filter(f => f.featured).map((f) => (
          <div class="card-outer group">
            <div class="card-inner-alt p-6 sm:p-8">
              <div class="flex flex-col sm:flex-row items-start gap-6">
                <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-discord/10 text-3xl text-discord transition-all duration-300 group-hover:bg-threat group-hover:text-white">
                  <Icon name={f.icon} />
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="mb-2 text-xl font-semibold text-white">{f.title}</h3>
                  <p class="text-sm leading-relaxed text-surface-400 max-w-2xl">{f.description}</p>
                </div>

              </div>
            </div>
          </div>
        ))}

        <!-- 2x2 grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {features.filter(f => !f.featured && !f.closing).map((f, i) => (
            <div class="card-outer group stagger-fade" style={`transition-delay: ${i * 80}ms`}>
              <div class="card-inner p-6">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-discord/10 text-2xl text-discord transition-all duration-300 group-hover:bg-threat group-hover:text-white">
                  <Icon name={f.icon} />
                </div>
                <h3 class="mb-2 text-lg font-semibold text-white">{f.title}</h3>
                <p class="text-sm leading-relaxed text-surface-400">{f.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Closing card (full-width) -->
        {features.filter(f => f.closing).map((f) => (
          <div class="card-outer group">
            <div class="card-inner-alt p-6 sm:p-8">
              <div class="flex flex-col sm:flex-row items-start gap-6">
                <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-discord/10 text-3xl text-discord transition-all duration-300 group-hover:bg-threat group-hover:text-white">
                  <Icon name={f.icon} />
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="mb-2 text-xl font-semibold text-white">{f.title}</h3>
                  <p class="text-sm leading-relaxed text-surface-400 max-w-2xl">{f.description}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="scroll-reveal section-scanline relative border-t border-surface-800 bg-surface-850 px-6 py-24 sm:py-32" data-reveal="none">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-4xl font-bold tracking-tight text-white md:text-5xl">
          Así funciona Threat
        </h2>
        <p class="mx-auto max-w-2xl text-surface-400">
          Cuatro etapas desde que llega un mensaje hasta que recibes la alerta.
        </p>
      </div>
      <div class="relative mx-auto max-w-3xl">
        <!-- Vertical connector line (hidden on mobile, visible sm+) -->
        <div class="hidden sm:block absolute left-8 lg:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-discord/40 via-surface-700 to-surface-700 lg:-translate-x-px"></div>

        {steps.map((step, i) => (
          <div class={`relative flex flex-col sm:flex-row items-start sm:items-center gap-6 pb-16 last:pb-0 ${i % 2 === 0 ? '' : 'lg:flex-row-reverse'}`}>
            <!-- Node dot -->
            <div class="relative z-10 flex items-center gap-4 sm:flex-col sm:w-16 lg:w-1/2 shrink-0">
              <span class="relative grid h-10 w-10 sm:h-12 sm:w-12 place-items-center rounded-full bg-surface-850 ring-2 ring-surface-700 font-mono text-xs sm:text-sm font-bold text-discord">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>

            <!-- Content card -->
            <div class="flex-1 min-w-0 card-outer group">
              <div class="card-inner p-5 sm:p-6">
                <div class="flex items-start gap-4">
                  <div class="hidden sm:flex mt-0.5 h-10 w-10 shrink-0 items-center justify-center rounded-full bg-discord/10 text-xl text-discord transition-all duration-300 group-hover:bg-threat group-hover:text-white">
                    <Icon name={step.icon} />
                  </div>
                  <div class="min-w-0">
                    <h3 class="mb-1.5 text-lg font-semibold text-white">{step.title}</h3>
                    <p class="text-sm leading-relaxed text-surface-400">{step.desc}</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMMANDS -->
  <section id="commands" class="scroll-reveal relative border-t border-surface-800 bg-surface-900 px-6 py-20 sm:py-28" data-reveal="subtle">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center">
        <h2 class="mb-4 text-4xl font-bold tracking-tight text-white md:text-5xl">
          Comandos
        </h2>
        <p class="mx-auto max-w-2xl text-surface-400">
          Ocho comandos para gestionar la seguridad de tu servidor.
        </p>
      </div>
      <div class="card-outer">
        <div class="card-inner-alt divide-y divide-surface-700/50 overflow-hidden">
          {commands.map((cmd, i) => (
            <div class="group flex items-center gap-3 sm:gap-4 px-4 sm:px-6 py-3.5 sm:py-4 transition-colors duration-200 hover:bg-surface-800/50">
              <div class="flex h-9 w-9 sm:h-10 sm:w-10 shrink-0 items-center justify-center rounded-full bg-surface-700 text-surface-400 transition-all duration-300 group-hover:bg-threat/20 group-hover:text-threat-light">
                <Icon name={cmd.icon} size="0.875em" />
              </div>
              <div class="flex-1 min-w-0 flex flex-col sm:flex-row sm:items-center gap-0.5 sm:gap-3">
                <div class="flex items-center gap-1.5">
                  <code class="font-mono text-sm font-medium text-white truncate">{cmd.name}</code>
