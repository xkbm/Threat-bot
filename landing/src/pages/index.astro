---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Stats from '../components/Stats.astro';
import Cta from '../components/Cta.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Navbar />
  <main>
    <Hero />

    <div class="h-24 bg-gradient-to-b from-bg-base to-bg-surface" />

    <div class="h-px bg-gradient-to-r from-transparent via-border-subtle to-transparent" />
    <Features />

    <div class="h-24 bg-gradient-to-b from-bg-surface to-bg-base" />

    <div class="h-px bg-gradient-to-r from-transparent via-border-subtle to-transparent" />
    <Stats />

    <div class="h-px bg-gradient-to-r from-transparent via-border-subtle to-transparent" />
    <Cta />

    <div class="h-24 bg-gradient-to-b from-bg-base to-bg-elevated" />

    <div class="h-px bg-gradient-to-r from-transparent via-border-subtle to-transparent" />
    <Footer />
  </main>
</BaseLayout>
