      <script type="module">
        document.addEventListener('DOMContentLoaded', () => {
          const demoScenarios = [
            {
              url: 'https://free-nitro.download/claim',
              titulo: 'Amenazas detectadas',
              emoji: '/emoji-warn.png',
              borderColor: 'rgb(230, 126, 34)',
              titleClass: 'text-surface-100',
              tipo: 'url',
              desc: (det) => `Se analizó <strong class="text-surface-100">1</strong> elemento(s):<br/>${EMOJI_CHECK_D} Seguros: <strong class="text-surface-100">0</strong><br/>${EMOJI_WARN_D} Maliciosos: <strong class="text-surface-100">${det}</strong>`,
              highlight: 'scenario-phishing',
            },
            {
              url: 'https://i.imgur.com/NSFWimage.jpg',
              titulo: 'Contenido NSFW detectado',
              emoji: '/emoji-warn.png',
              borderColor: 'rgb(232, 197, 71)',
              titleClass: 'text-surface-100',
              tipo: 'nsfw',
              desc: () => `Se analizó <strong class="text-surface-100">1</strong> elemento(s):<br/>${EMOJI_CHECK_D} Seguros: <strong class="text-surface-100">0</strong><br/>${EMOJI_NSFW_D} NSFW: <strong class="text-surface-100">1</strong>`,
              highlight: 'scenario-nsfw',
            },
            {
              url: 'https://www.youtube.com/watch?v=dQw4w9WgXcQ',
              titulo: '',
              emoji: '/emoji-whitelist.png',
              borderColor: 'var(--color-secure)',
              titleClass: 'text-surface-100',
              tipo: 'whitelist',
              desc: () => '',
              highlight: 'scenario-safe',
            },
          ];
          const EMOJI_CHECK_D = '<img src="/emoji-check.png" class="inline w-4 h-4" width="16" height="16" alt="" />';
          const EMOJI_WARN_D = '<img src="/emoji-warn.png" class="inline w-4 h-4" width="16" height="16" alt="" />';
          const EMOJI_NSFW_D = '<img src="/emoji-nsfw.png" class="inline w-4 h-4" width="16" height="16" alt="" />';
          const EMOJI_LINK_D = '<img src="/emoji-link.png" class="inline w-4 h-4" width="16" height="16" alt="" />';

          function rand(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
          const usuarios = ['Carlos', 'Laura', 'Pedro', 'Sofía', 'Ana', 'Luis'];

          let current = 0;

          function runDemo() {
            const s = demoScenarios[current];
            const msg1 = document.getElementById('demo-msg-1');
            const msg2 = document.getElementById('demo-msg-2');
            const typing = document.getElementById('demo-typing');
            const response = document.getElementById('demo-response');
            const card = document.getElementById('demo-response-card');
            const text = document.getElementById('demo-response-text');
            const emoji = document.getElementById('demo-response-emoji');
            const title = document.getElementById('demo-response-title');
            const desc = document.getElementById('demo-response-desc');
            const urlField = document.getElementById('demo-response-url-field');
            const urlValues = document.getElementById('demo-response-url-values');
            const nsfwField = document.getElementById('demo-response-nsfw-field');
            const nsfwValues = document.getElementById('demo-response-nsfw-values');
            const malField = document.getElementById('demo-response-mal-field');
            const malValues = document.getElementById('demo-response-mal-values');

            // Reset
            [msg1, msg2, typing, response].forEach(el => {
              el.classList.add('opacity-0');
              el.classList.remove('animate-slide-up');
            });

            // Highlight active scenario
            document.querySelectorAll('[id^="scenario-"]').forEach(el => {
              el.style.borderColor = '';
              el.classList.remove('ring-1', 'ring-shield/30');
            });
            const activeEl = document.getElementById(s.highlight);
            if (activeEl) {
              activeEl.classList.add('ring-1', 'ring-shield/30');
            }

            // Set conversation
            const u1 = rand(usuarios);
            let u2;
            do { u2 = rand(usuarios); } while (u2 === u1);
            msg1.querySelector('.font-mono').textContent = u1;
            msg1.querySelector('.text-surface-300').textContent = s.tipo === 'whitelist' ? 'Miren este video' : 'Alguien pasó un link raro';
            msg2.querySelector('.font-mono').textContent = u2;
            const urlTextEl = msg2.querySelector('.demo-chat-url');
            urlTextEl.textContent = s.url;

            // Set response
            if (s.tipo === 'whitelist') {
              card.classList.add('hidden');
              text.classList.remove('hidden');
            } else {
              card.classList.remove('hidden');
              text.classList.add('hidden');
              card.style.borderLeftColor = s.borderColor;
              emoji.src = s.emoji;
              title.textContent = s.titulo;
              title.setAttribute('class', `text-sm font-semibold ${s.titleClass}`);
              const det = Math.floor(Math.random() * 22) + 3;
              desc.innerHTML = s.desc(det);

              // Hide all fields first
              urlField.classList.add('hidden');
              nsfwField.classList.add('hidden');
              malField.classList.add('hidden');

              if (s.tipo === 'url') {
                urlField.classList.remove('hidden');
                urlValues.innerHTML = `${EMOJI_WARN_D} <code class="font-mono text-xs text-surface-200 bg-surface-700 px-1 py-0.5 rounded">${s.url}</code>`;
                malField.classList.remove('hidden');
                const urlId = btoa(s.url).replace(/=+$/, '');
                const vtLink = `https://www.virustotal.com/gui/url/${urlId}`;
                malValues.innerHTML = `<span class="text-xs text-surface-300">• <code class="font-mono text-xs text-surface-200 bg-surface-700 px-1 py-0.5 rounded">${s.url}</code> <a href="${vtLink}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-0.5 text-shield-light hover:underline">${EMOJI_LINK_D} Ver informe</a></span>`;
              } else if (s.tipo === 'nsfw') {
                urlField.classList.remove('hidden');
                urlValues.innerHTML = `${EMOJI_NSFW_D} <code class="font-mono text-xs text-surface-200 bg-surface-700 px-1 py-0.5 rounded">${s.url}</code>`;
                nsfwField.classList.remove('hidden');
                nsfwValues.innerHTML = `<span class="text-xs text-surface-300">Desnudez <strong class="text-surface-100">72%</strong>, Armas <strong class="text-surface-100">55%</strong></span>`;
              }
            }

            // Animate
            setTimeout(() => {
              msg1.classList.remove('opacity-0');
              msg1.classList.add('animate-slide-up');
            }, 200);
            setTimeout(() => {
              msg2.classList.remove('opacity-0');
              msg2.classList.add('animate-slide-up');
            }, 700);
            setTimeout(() => {
              typing.classList.remove('opacity-0');
            }, 1200);
            setTimeout(() => {
              typing.classList.add('opacity-0');
              response.classList.remove('opacity-0');
              response.classList.add('animate-slide-up');
            }, 2200);

            current = (current + 1) % demoScenarios.length;
          }

          // Start after a short delay, then cycle
          setTimeout(() => {
            runDemo();
            setInterval(runDemo, 7000);
          }, 1000);
        });
      </script>
    </div>
  </section>

  <!-- Stack: Debajo del capó -->
