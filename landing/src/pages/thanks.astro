---
import BaseLayout from '../layouts/BaseLayout.astro';

const steps = [
  {
    icon: 'las la-hashtag',
    title: 'Canal de logs',
    desc: 'Usa /setlogchannel para elegir dónde recibir alertas de seguridad.',
  },
  {
    icon: 'las la-gavel',
    title: 'Modo estricto',
    desc: 'Activa /strictmode para eliminar automáticamente mensajes sospechosos.',
  },
  {
    icon: 'las la-cog',
    title: 'Configuración',
    desc: 'Revisa y ajusta todo con /settings desde tu servidor.',
  },
  {
    icon: 'las la-question-circle',
    title: 'Ayuda',
    desc: 'Consulta /help para ver la lista completa de comandos disponibles.',
  },
];
---

<BaseLayout
  title="¡Gracias por invitar a Threat! — Seguridad inteligente para Discord"
  description="Threat ya está en tu servidor. Configura el bot en minutos con /setlogchannel, /strictmode y más."
>
  <section class="hero-gradient relative flex min-h-screen items-center justify-center px-6 pt-20 sm:pt-24">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/4 top-1/4 h-72 w-72 rounded-full bg-discord opacity-[0.08] blur-[120px] animate-float"></div>
      <div class="absolute right-1/4 bottom-1/4 h-96 w-96 rounded-full bg-discord opacity-[0.05] blur-[150px] animate-float-delayed"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl w-full pb-16 sm:pb-24">
      <div class="flex flex-col items-center text-center">
        <div class="mb-8 flex h-20 w-20 animate-fade-up items-center justify-center rounded-2xl bg-discord/20 text-5xl text-discord">
          <i class="las la-check-circle" aria-hidden="true"></i>
        </div>

        <h1 class="mb-4 max-w-2xl text-5xl font-black leading-none tracking-tight sm:text-6xl md:text-7xl">
          <span class="gradient-text">Threat</span> está en tu servidor
        </h1>

        <p class="mb-12 max-w-xl text-base text-surface-400 sm:text-lg">
          Gracias por confiar en Threat para proteger tu comunidad.
          Configúralo en minutos y empieza a recibir alertas.
        </p>

        <div class="mb-12 w-16 border-t border-surface-700"></div>

        <h2 class="mb-2 text-sm font-semibold uppercase tracking-widest text-surface-500">Pasos siguientes</h2>
        <div class="mb-12 grid gap-4 sm:grid-cols-2 w-full max-w-2xl">
          {
            steps.map((s) => (
              <div class="card-hover group rounded-2xl border border-surface-700 bg-surface-800/50 p-5 text-left transition-all duration-300">
                <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-xl bg-discord/10 text-xl text-discord transition-all duration-300 group-hover:bg-discord group-hover:text-white">
                  <i class={s.icon} aria-hidden="true"></i>
                </div>
                <h3 class="mb-1 text-sm font-semibold text-white">{s.title}</h3>
                <p class="text-xs leading-relaxed text-surface-400">{s.desc}</p>
              </div>
            ))
          }
        </div>

        <div class="flex flex-col items-center gap-4 sm:flex-row animate-fade-up-delayed">
          <a href="/" class="group inline-flex items-center gap-2 rounded-xl bg-discord px-8 py-3.5 font-semibold text-white transition-all duration-300 hover:bg-discord-light hover:scale-105 hover:shadow-[0_0_40px_rgba(88,101,242,0.4)]">
            <i class="las la-arrow-left text-lg" aria-hidden="true"></i>
            Volver al inicio
          </a>
          <a href="https://discord.com/api/oauth2/authorize?client_id=1038186932456390726&permissions=277025745990&scope=bot+applications.commands" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-2 rounded-xl border border-surface-600 px-8 py-3.5 font-semibold text-surface-300 transition-all duration-300 hover:border-surface-400 hover:text-white">
            <i class="las la-plus text-lg" aria-hidden="true"></i>
            Invitar a otro servidor
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
