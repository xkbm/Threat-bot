<section class="relative flex min-h-screen items-center overflow-hidden px-6 pt-24">
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top_right,_rgba(88,101,242,0.12),transparent_50%)]"
  />
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(237,66,69,0.06),transparent_50%)]"
  />
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-3xl text-center">
      <div
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-border-subtle bg-bg-surface px-4 py-1.5 text-xs font-medium text-text-muted"
      >
        <span
          class="flex h-2 w-2 animate-pulse-dot rounded-full bg-green shadow-[0_0_8px_#57f287]"
        >
        </span>
        Versión 2.0 — Ahora con análisis de imágenes
      </div>
      <h1
        class="font-heading text-5xl font-bold leading-tight tracking-tight text-text-primary md:text-6xl lg:text-7xl"
