      <div class="mt-10 flex items-center justify-center gap-4">
        <a
          href="https://discord.com/api/oauth2/authorize?client_id=1038186932456390726&permissions=277025745990&scope=bot+applications.commands"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg bg-blurple px-8 py-3.5 font-heading text-base font-bold text-white shadow-lg shadow-blurple/25 transition-all hover:bg-blurple-hover hover:shadow-blurple/40"
        >
          Invitar al bot
        </a>
        <a
          href="#features"
          class="rounded-lg border border-border-strong bg-bg-elevated px-8 py-3.5 font-heading text-base font-bold text-text-primary transition-colors hover:bg-bg-hover"
