---
import { Shield } from '@lucide/astro';

const year = new Date().getFullYear();
---

<footer class="bg-bg-elevated px-6 py-12">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex items-center gap-2">
        <div
          class="flex h-7 w-7 items-center justify-center rounded-md bg-blurple text-white"
        >
          <Shield size={15} stroke-width={2} />
        </div>
        <span class="font-heading text-sm font-semibold text-text-primary"
          >Threat-bot</span
        >
      </div>
      <div class="flex items-center gap-6 text-sm text-text-muted">
        <a
          href="#features"
          class="transition-colors hover:text-text-primary"
        >
          Features
        </a>
        <a href="#stats" class="transition-colors hover:text-text-primary">
          Estadísticas
        </a>
        <a
          href="https://github.com/xkbm/Threat-bot"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-text-primary"
        >
          GitHub
        </a>
        <a
          href="https://discord.com/api/oauth2/authorize?client_id=1038186932456390726&permissions=277025745990&scope=bot+applications.commands"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-text-primary"
        >
          Invitar
        </a>
      </div>
      <p class="text-xs text-text-muted">
        &copy; {year} Threat-bot. MIT License.
      </p>
    </div>
  </div>
</footer>
