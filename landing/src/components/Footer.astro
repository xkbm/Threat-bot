---

const year = new Date().getFullYear();
---

<footer class="border-t border-border-subtle px-6 py-12">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex items-center gap-2">
        <span
          class="flex h-7 w-7 items-center justify-center rounded-md bg-blurple font-heading text-xs font-bold text-white"
        >
          T
        </span>
        <span class="font-heading text-sm font-semibold text-text-primary"
          >Threat-bot</span
        >
      </div>
      <div class="flex items-center gap-6 text-sm text-text-muted">
        <a
          href="#features"
          class="transition-colors hover:text-text-primary"
        >
          Features
        </a>
        <a href="#stats" class="transition-colors hover:text-text-primary">
          Estadísticas
        </a>
        <a
          href="https://github.com/xkbm/Threat-bot"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-text-primary"
        >
          GitHub
        </a>
        <a
          href="https://discord.com/oauth2/authorize"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-text-primary"
        >
          Invitar
        </a>
      </div>
      <p class="text-xs text-text-muted">
        &copy; {year} Threat-bot. MIT License.
      </p>
    </div>
  </div>
</footer>
