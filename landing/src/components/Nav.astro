---
const links = [
  { href: '/#threats', label: 'Amenazas' },
  { href: '/#demo', label: 'Demo' },
  { href: '/#stack', label: 'Stack' },
  { href: '/#stats', label: 'Estadísticas' },
];
---

<!-- Desktop nav -->
<nav class="nav-desktop hidden md:flex items-center gap-1" aria-label="Navegación principal">
  <a href="/#threats" class="rounded-full px-4 py-2 text-sm text-surface-400 transition-colors duration-200 hover:text-surface-200">Amenazas</a>
  <a href="/#demo" class="rounded-full px-4 py-2 text-sm text-surface-400 transition-colors duration-200 hover:text-surface-200">Demo</a>
  <a href="/#stack" class="rounded-full px-4 py-2 text-sm text-surface-400 transition-colors duration-200 hover:text-surface-200">Stack</a>
  <a href="/#stats" class="rounded-full px-4 py-2 text-sm text-surface-400 transition-colors duration-200 hover:text-surface-200">Estadísticas</a>
</nav>

<!-- Mobile hamburger button -->
<button
  id="nav-toggle"
  class="nav-toggle md:hidden relative z-[70] inline-flex items-center justify-center rounded-full p-2.5 text-surface-400 hover:text-surface-200 transition-colors duration-200"
  aria-label="Abrir menú de navegación"
  aria-expanded="false"
  aria-controls="nav-mobile-menu"
>
  <svg class="nav-icon-open" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="3" y1="6" x2="21" y2="6" />
    <line x1="3" y1="12" x2="21" y2="12" />
    <line x1="3" y1="18" x2="21" y2="18" />
  </svg>
  <svg class="nav-icon-close hidden" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M18 6 6 18" />
    <path d="m6 6 12 12" />
  </svg>
</button>

<!-- Mobile menu overlay — moved OUTSIDE the fixed header container via teleport -->
<div
  id="nav-mobile-menu"
  class="fixed inset-0 z-[60] hidden bg-surface-900/95 backdrop-blur-sm"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
>
  <div class="flex flex-col items-center justify-center min-h-[100dvh] gap-8 px-6 pt-20 pb-20">
    {links.map((link) => (
      <a
        href={link.href}
        class="nav-mobile-link text-2xl font-semibold text-surface-300 transition-colors duration-200 hover:text-white"
      >
        {link.label}
      </a>
    ))}
  </div>
</div>

<script is:inline>
  (function() {
    var toggle = document.getElementById('nav-toggle');
    var overlay = document.getElementById('nav-mobile-menu');
    var iconOpen = toggle ? toggle.querySelector('.nav-icon-open') : null;
    var iconClose = toggle ? toggle.querySelector('.nav-icon-close') : null;
    var links = document.querySelectorAll('.nav-mobile-link');

    if (!toggle || !overlay) return;

    function openMenu() {
      // Lock body scroll — works on iOS too with position:fixed
      var scrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = '-' + scrollY + 'px';
      document.body.style.width = '100%';
      // Show menu
      overlay.classList.remove('hidden');
      overlay.setAttribute('aria-hidden', 'false');
      // Swap icon
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Cerrar menú de navegación');
    }

    function closeMenu() {
      // Unlock body scroll
      var scrollY = document.body.style.top;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      if (scrollY) window.scrollTo(0, parseInt(scrollY || '0') * -1);
      // Hide menu
      overlay.classList.add('hidden');
      overlay.setAttribute('aria-hidden', 'true');
      // Swap icon back
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Abrir menú de navegación');
    }

    // Use click (not just pointerup) to be reliable on mobile
    toggle.addEventListener('click', function(e) {
      e.stopPropagation();
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      if (expanded) { closeMenu(); } else { openMenu(); }
    });

    // Close on link click
    links.forEach(function(link) {
      link.addEventListener('click', closeMenu);
    });

    // Close on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      }
    });

    // Close when clicking the overlay backdrop (not the links inside)
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) { closeMenu(); }
    });

    // Close if resized to desktop
    window.addEventListener('resize', function() {
      if (window.innerWidth >= 768 && toggle.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      }
    });
  })();
</script>
