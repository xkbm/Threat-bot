<section class="scroll-reveal section-scanline stats-section relative border-t border-surface-800 bg-surface-850 px-6 py-20 sm:py-28" data-reveal="up" id="stats">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-4xl font-bold tracking-tight text-white md:text-5xl">
        Threat en números
      </h2>
      <p class="mx-auto max-w-2xl text-surface-400">
        Datos reales de uso del bot. Actualizados cada 5 minutos.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      <div class="spotlight-item relative bg-surface-900 rounded-xl p-5 text-center border border-surface-800">
        <div id="stat-total" class="stat-digit text-3xl sm:text-4xl font-bold text-white font-mono">—</div>
        <div class="mt-1 text-xs text-surface-400 uppercase tracking-wider">Análisis totales</div>
      </div>
      <div class="spotlight-item relative bg-surface-900 rounded-xl p-5 text-center border border-surface-800">
        <div id="stat-seguros" class="stat-digit text-3xl sm:text-4xl font-bold font-mono" style="color: var(--stat-secure);">—</div>
        <div class="mt-1 text-xs text-surface-400 uppercase tracking-wider">Seguros</div>
      </div>
      <div class="spotlight-item relative bg-surface-900 rounded-xl p-5 text-center border border-surface-800">
        <div id="stat-maliciosos" class="stat-digit text-3xl sm:text-4xl font-bold font-mono" style="color: var(--stat-threat);">—</div>
        <div class="mt-1 text-xs text-surface-400 uppercase tracking-wider">Maliciosos</div>
      </div>
      <div class="spotlight-item relative bg-surface-900 rounded-xl p-5 text-center border border-surface-800">
        <div id="stat-nsfw" class="stat-digit text-3xl sm:text-4xl font-bold font-mono" style="color: var(--stat-nsfw);">—</div>
        <div class="mt-1 text-xs text-surface-400 uppercase tracking-wider">NSFW</div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-surface-800 rounded-xl overflow-hidden">
      <div class="bg-surface-900 p-5">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-surface-400">VirusTotal /día</span>
          <span id="vt-daily-val" class="text-xs font-mono text-surface-300">—</span>
        </div>
        <div class="h-1.5 rounded-full bg-surface-700 overflow-hidden">
          <div id="vt-daily-bar" class="h-full rounded-full transition-all duration-500" style="width: 0%; background: var(--stat-bar-vt);"></div>
        </div>
      </div>
      <div class="bg-surface-900 p-5">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-surface-400">SightEngine /día</span>
          <span id="se-daily-val" class="text-xs font-mono text-surface-300">—</span>
        </div>
        <div class="h-1.5 rounded-full bg-surface-700 overflow-hidden">
          <div id="se-daily-bar" class="h-full rounded-full transition-all duration-500" style="width: 0%; background: var(--stat-bar-se);"></div>
        </div>
      </div>
    </div>

    <p id="stat-timestamp" class="mt-6 text-center text-xs text-surface-500"></p>
  </div>

  <style>
    .stats-section {
      --stat-secure: #22C55E;
      --stat-threat: #EF4444;
      --stat-nsfw: #F97316;
      --stat-bar-vt: #3B82F6;
      --stat-bar-se: #F97316;
    }
    @supports (color: oklch(...)) {
      .stats-section {
        --stat-secure: oklch(0.62 0.19 145);
        --stat-threat: oklch(0.6 0.22 30);
        --stat-nsfw: oklch(0.65 0.2 45);
        --stat-bar-vt: oklch(0.55 0.18 265);
        --stat-bar-se: oklch(0.65 0.2 45);
      }
    }

    .stat-digit {
      position: relative;
      overflow: hidden;
      line-height: 1.2;
    }
    .odometer-inner {
      display: block;
      transition: transform 350ms cubic-bezier(.2,.8,.3,1), opacity 350ms ease;
    }
    .odometer-exit {
      position: absolute;
      left: 0;
      right: 0;
      top: 0;
      transform: translateY(0);
      opacity: 1;
    }
    .odometer-exit.active {
      transform: translateY(-100%);
      opacity: 0;
    }
    .odometer-entry {
      transform: translateY(100%);
      opacity: 0;
    }
    .odometer-entry.active {
      transform: translateY(0);
      opacity: 1;
    }
  </style>

  <script is:inline>
    (function () {
      function formatNum(n) {
        return n >= 1000 ? n.toLocaleString('es-AR') : String(n);
      }

      var wrappers = {};

      function createWrapper(id) {
        var el = document.getElementById(id);
        var span = document.createElement('span');
        span.className = 'odometer-inner';
        span.textContent = el.textContent;
        el.textContent = '';
        el.appendChild(span);
        wrappers[id] = el;
      }

      function animateValue(id, newText) {
        var w = wrappers[id];
        if (!w) return;
        var oldSpan = w.querySelector('.odometer-inner');
        if (!oldSpan || oldSpan.textContent === newText) return;

        oldSpan.className = 'odometer-inner odometer-exit';

        var newSpan = document.createElement('span');
        newSpan.className = 'odometer-inner odometer-entry';
        newSpan.textContent = newText;
        w.appendChild(newSpan);

        requestAnimationFrame(function () {
          oldSpan.classList.add('active');
          newSpan.classList.add('active');
        });

        setTimeout(function () {
          if (oldSpan.parentNode) oldSpan.parentNode.removeChild(oldSpan);
        }, 400);
      }

      function updateUI(data) {
        animateValue('stat-total', formatNum(data.total));
        animateValue('stat-seguros', formatNum(data.seguros));
        animateValue('stat-maliciosos', formatNum(data.maliciosos));
        animateValue('stat-nsfw', formatNum(data.nsfw));

        document.getElementById('vt-daily-val').textContent = data.vt_usage_diario + '%';
        document.getElementById('vt-daily-bar').style.width = data.vt_usage_diario + '%';
        document.getElementById('se-daily-val').textContent = data.se_usage_diario + '%';
        document.getElementById('se-daily-bar').style.width = data.se_usage_diario + '%';

        if (data.timestamp > 0) {
          var d = new Date(data.timestamp * 1000);
          document.getElementById('stat-timestamp').textContent = 'Última actualización: ' + d.toLocaleString('es-AR');
        }
      }

      function fetchStats() {
        fetch('/api/stats?_=' + Date.now(), {
          headers: { 'Pragma': 'no-cache' }
        })
          .then(function (r) { return r.json(); })
          .then(function (data) { updateUI(data); })
          .catch(function () {});
      }

      createWrapper('stat-total');
      createWrapper('stat-seguros');
      createWrapper('stat-maliciosos');
      createWrapper('stat-nsfw');

      fetchStats();
      setInterval(fetchStats, 10000);
    })();
  </script>
</section>
